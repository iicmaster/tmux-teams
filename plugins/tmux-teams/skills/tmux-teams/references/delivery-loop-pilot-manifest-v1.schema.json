{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delivery-loop-pilot-manifest-v1.schema.json",
  "title": "tmux-teams Delivery Loop Stage 1 Pilot Manifest v1",
  "description": "Frozen prospective contract for one observational Stage 1 field pilot. The manifest binds the handoff boundary, eligibility, assignment commitment, sample and maturity rules, stopping rules, complete instrumentation, missing-data and contamination handling, separated roles, and an external custody anchor. manifest_digest is the SHA-256 digest of the canonical document with manifest_digest omitted and with any detached signature stored outside this document.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "manifest_id",
    "experiment_id",
    "manifest_digest",
    "frozen_at",
    "automatic_routing",
    "boundary",
    "hypothesis",
    "primary_kpis",
    "guardrails",
    "eligibility",
    "assignment",
    "sample_plan",
    "maturity",
    "stopping_rule",
    "thresholds",
    "cost_model",
    "cost_instrumentation",
    "outcome_instrumentation",
    "guardrail_instrumentation",
    "missing_data",
    "contamination",
    "actors",
    "roles",
    "role_separation",
    "external_anchor",
    "analysis_plan"
  ],
  "properties": {
    "schema": { "const": "tmux-teams.delivery-loop-pilot-manifest" },
    "schema_version": { "const": 1 },
    "manifest_id": { "$ref": "#/$defs/id" },
    "experiment_id": { "$ref": "#/$defs/id" },
    "manifest_digest": { "$ref": "#/$defs/digest" },
    "frozen_at": { "$ref": "#/$defs/timestamp" },
    "automatic_routing": {
      "description": "The Stage 1 toolkit is observational and must never select or dispatch a worker.",
      "const": false
    },
    "boundary": { "$ref": "#/$defs/boundary" },
    "hypothesis": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1000,
      "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
    },
    "primary_kpis": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "total_coordination_minutes",
          "incremental_loaded_cost",
          "time_to_usable_outcome_minutes",
          "value_proxy"
        ]
      }
    },
    "guardrails": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "security",
          "performance",
          "integration",
          "uat",
          "escaped_defects"
        ]
      }
    },
    "eligibility": { "$ref": "#/$defs/eligibility" },
    "assignment": { "$ref": "#/$defs/assignment" },
    "sample_plan": { "$ref": "#/$defs/sample_plan" },
    "maturity": { "$ref": "#/$defs/maturity" },
    "stopping_rule": { "$ref": "#/$defs/stopping_rule" },
    "thresholds": { "$ref": "#/$defs/thresholds" },
    "cost_model": { "$ref": "#/$defs/cost_model" },
    "cost_instrumentation": { "$ref": "#/$defs/cost_instrumentation" },
    "outcome_instrumentation": { "$ref": "#/$defs/outcome_instrumentation" },
    "guardrail_instrumentation": {
      "$ref": "#/$defs/guardrail_instrumentation"
    },
    "missing_data": { "$ref": "#/$defs/missing_data" },
    "contamination": { "$ref": "#/$defs/contamination" },
    "actors": { "$ref": "#/$defs/actors" },
    "roles": { "$ref": "#/$defs/roles" },
    "role_separation": { "$ref": "#/$defs/role_separation" },
    "external_anchor": { "$ref": "#/$defs/external_anchor" },
    "analysis_plan": { "$ref": "#/$defs/analysis_plan" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_][A-Za-z0-9_-]{0,63}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])T(?:[01]\\d|2[0-3]):[0-5]\\d:[0-5]\\d(?:\\.\\d+)?(?:Z|[+-](?:[01]\\d|2[0-3]):[0-5]\\d)$"
    },
    "reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
    },
    "statement": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
    },
    "id_list": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "boundary": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sender_phase", "receiver_phase", "artifact_type"],
          "properties": {
            "sender_phase": { "const": "Requirement" },
            "receiver_phase": { "const": "Prototype" },
            "artifact_type": { "const": "requirements_baseline" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sender_phase", "receiver_phase", "artifact_type"],
          "properties": {
            "sender_phase": { "const": "Prototype" },
            "receiver_phase": { "const": "Development" },
            "artifact_type": { "const": "prototype_evaluation" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sender_phase", "receiver_phase", "artifact_type"],
          "properties": {
            "sender_phase": { "const": "Development" },
            "receiver_phase": { "const": "QA" },
            "artifact_type": { "const": "development_delivery" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sender_phase", "receiver_phase", "artifact_type"],
          "properties": {
            "sender_phase": { "const": "QA" },
            "receiver_phase": { "const": "ProjectDelivery" },
            "artifact_type": { "const": "qa_release_evidence" }
          }
        }
      ]
    },
    "eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "population_description",
        "inclusion_criteria",
        "exclusion_criteria",
        "stable_slice_id_method",
        "eligible_source_ref",
        "eligible_source_digest",
        "strata",
        "enrollment_policy",
        "eligibility_owner_actor_id"
      ],
      "properties": {
        "population_description": { "$ref": "#/$defs/statement" },
        "inclusion_criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/statement" }
        },
        "exclusion_criteria": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/statement" }
        },
        "stable_slice_id_method": {
          "enum": [
            "canonical_source_id",
            "sha256_canonical_eligibility_record_v1"
          ]
        },
        "eligible_source_ref": { "$ref": "#/$defs/reference" },
        "eligible_source_digest": { "$ref": "#/$defs/digest" },
        "strata": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "enrollment_policy": { "const": "prospective_all_eligible" },
        "eligibility_owner_actor_id": { "$ref": "#/$defs/id" }
      }
    },
    "assignment_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "interval"],
      "properties": {
        "start": { "$ref": "#/$defs/timestamp" },
        "end": { "$ref": "#/$defs/timestamp" },
        "interval": { "const": "half_open_start_inclusive_end_exclusive" }
      }
    },
    "allocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pm_routed", "receiver_owned"],
      "properties": {
        "pm_routed": { "const": 1 },
        "receiver_owned": { "const": 1 }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "method_version",
        "arms",
        "control_arm",
        "treatment_arm",
        "allocation",
        "seed_commitment",
        "assignment_window",
        "assignment_custodian_actor_id",
        "arm_override_allowed",
        "retain_assigned_arm"
      ],
      "properties": {
        "method": { "const": "hmac_sha256_stratified_v1" },
        "method_version": { "const": 1 },
        "arms": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "enum": ["pm_routed", "receiver_owned"] }
        },
        "control_arm": { "const": "pm_routed" },
        "treatment_arm": { "const": "receiver_owned" },
        "allocation": { "$ref": "#/$defs/allocation" },
        "seed_commitment": {
          "description": "Commitment only. The unrevealed assignment seed must not appear in this manifest or a worker-writable repository.",
          "$ref": "#/$defs/digest"
        },
        "assignment_window": { "$ref": "#/$defs/assignment_window" },
        "assignment_custodian_actor_id": { "$ref": "#/$defs/id" },
        "arm_override_allowed": { "const": false },
        "retain_assigned_arm": { "const": true }
      }
    },
    "sample_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_assigned_per_arm",
        "min_mature_per_arm",
        "target_assigned_total",
        "power_method",
        "power_reference",
        "rationale"
      ],
      "properties": {
        "min_assigned_per_arm": { "type": "integer", "minimum": 1 },
        "min_mature_per_arm": { "type": "integer", "minimum": 1 },
        "target_assigned_total": { "type": "integer", "minimum": 2 },
        "power_method": {
          "enum": [
            "simulation",
            "analytic",
            "precision_target",
            "feasibility_bound"
          ]
        },
        "power_reference": { "$ref": "#/$defs/reference" },
        "rationale": { "$ref": "#/$defs/statement" }
      }
    },
    "maturity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_follow_up_days",
        "outcome_states",
        "endpoint_definition",
        "maturity_owner_actor_id"
      ],
      "properties": {
        "min_follow_up_days": { "type": "integer", "minimum": 0 },
        "outcome_states": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "enum": [
              "mature",
              "immature",
              "censored",
              "pending",
              "cancelled",
              "abandoned"
            ]
          }
        },
        "endpoint_definition": { "$ref": "#/$defs/statement" },
        "maturity_owner_actor_id": { "$ref": "#/$defs/id" }
      }
    },
    "stopping_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_end",
        "max_assigned_slices",
        "allowed_stop_reasons",
        "manual_stop_owner_actor_id",
        "post_outcome_rule_changes_allowed",
        "automatic_safety_actuation"
      ],
      "properties": {
        "window_end": { "$ref": "#/$defs/timestamp" },
        "max_assigned_slices": { "type": "integer", "minimum": 2 },
        "allowed_stop_reasons": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "ASSIGNMENT_WINDOW_ENDED",
              "MAX_ASSIGNED_REACHED",
              "EXTERNAL_SAFETY_HOLD",
              "SOURCE_UNAVAILABLE",
              "GOVERNANCE_WITHDRAWAL"
            ]
          }
        },
        "manual_stop_owner_actor_id": { "$ref": "#/$defs/id" },
        "post_outcome_rule_changes_allowed": { "const": false },
        "automatic_safety_actuation": { "const": false }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_mature_per_arm",
        "coordination_reduction_percent",
        "incremental_cost_reduction_percent",
        "time_to_usable_noninferiority_minutes",
        "value_noninferiority_margin"
      ],
      "properties": {
        "min_mature_per_arm": { "type": "integer", "minimum": 1 },
        "coordination_reduction_percent": {
          "type": "number",
          "minimum": 0
        },
        "incremental_cost_reduction_percent": {
          "type": "number",
          "minimum": 0
        },
        "time_to_usable_noninferiority_minutes": {
          "type": "number",
          "minimum": 0
        },
        "value_noninferiority_margin": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "cost_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loaded_cost_per_minute",
        "currency",
        "unit",
        "allocation_basis"
      ],
      "properties": {
        "loaded_cost_per_minute": { "type": "number", "minimum": 0 },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "unit": { "const": "minute" },
        "allocation_basis": { "$ref": "#/$defs/statement" }
      }
    },
    "measurement_method": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_id",
        "method",
        "owner_actor_id",
        "source_kind",
        "unit",
        "unknown_value_policy"
      ],
      "properties": {
        "method_id": { "$ref": "#/$defs/id" },
        "method": { "$ref": "#/$defs/statement" },
        "owner_actor_id": { "$ref": "#/$defs/id" },
        "source_kind": {
          "enum": [
            "mailbox_dispatch",
            "mailbox_outbox",
            "kms_event",
            "manual_observation",
            "derived_from_named_observations"
          ]
        },
        "unit": { "const": "minute" },
        "unknown_value_policy": { "const": "record_explicit_null" }
      }
    },
    "cost_instrumentation": {
      "type": "object",
      "description": "Every cost category is mandatory and independently binds a method and accountable owner.",
      "additionalProperties": false,
      "required": [
        "pm_routing_minutes",
        "pm_exception_minutes",
        "pm_evidence_minutes",
        "receiver_review_minutes",
        "governance_minutes",
        "instrumentation_minutes",
        "queue_wait_minutes",
        "rework_minutes",
        "rejected_work_minutes",
        "abandoned_work_minutes",
        "cancelled_work_minutes",
        "sender_coordination_minutes"
      ],
      "properties": {
        "pm_routing_minutes": { "$ref": "#/$defs/measurement_method" },
        "pm_exception_minutes": { "$ref": "#/$defs/measurement_method" },
        "pm_evidence_minutes": { "$ref": "#/$defs/measurement_method" },
        "receiver_review_minutes": { "$ref": "#/$defs/measurement_method" },
        "governance_minutes": { "$ref": "#/$defs/measurement_method" },
        "instrumentation_minutes": { "$ref": "#/$defs/measurement_method" },
        "queue_wait_minutes": { "$ref": "#/$defs/measurement_method" },
        "rework_minutes": { "$ref": "#/$defs/measurement_method" },
        "rejected_work_minutes": { "$ref": "#/$defs/measurement_method" },
        "abandoned_work_minutes": { "$ref": "#/$defs/measurement_method" },
        "cancelled_work_minutes": { "$ref": "#/$defs/measurement_method" },
        "sender_coordination_minutes": { "$ref": "#/$defs/measurement_method" }
      }
    },
    "outcome_metric_method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method_id", "method", "owner_actor_id", "unit"],
      "properties": {
        "method_id": { "$ref": "#/$defs/id" },
        "method": { "$ref": "#/$defs/statement" },
        "owner_actor_id": { "$ref": "#/$defs/id" },
        "unit": {
          "enum": ["minute", "declared_value_unit", "status_code"]
        }
      }
    },
    "outcome_instrumentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_to_usable_outcome_minutes",
        "value_proxy",
        "maturity_status"
      ],
      "properties": {
        "time_to_usable_outcome_minutes": {
          "$ref": "#/$defs/outcome_metric_method"
        },
        "value_proxy": { "$ref": "#/$defs/outcome_metric_method" },
        "maturity_status": {
          "$ref": "#/$defs/outcome_metric_method"
        }
      }
    },
    "guardrail_method": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method_id",
        "method",
        "owner_actor_id",
        "evidence_requirement"
      ],
      "properties": {
        "method_id": { "$ref": "#/$defs/id" },
        "method": { "$ref": "#/$defs/statement" },
        "owner_actor_id": { "$ref": "#/$defs/id" },
        "evidence_requirement": {
          "const": "named_reference_and_sha256_digest"
        }
      }
    },
    "guardrail_instrumentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "security",
        "performance",
        "integration",
        "uat",
        "escaped_defects"
      ],
      "properties": {
        "security": { "$ref": "#/$defs/guardrail_method" },
        "performance": { "$ref": "#/$defs/guardrail_method" },
        "integration": { "$ref": "#/$defs/guardrail_method" },
        "uat": { "$ref": "#/$defs/guardrail_method" },
        "escaped_defects": { "$ref": "#/$defs/guardrail_method" }
      }
    },
    "missing_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximum_unknown_cost_fraction",
        "maximum_missing_mature_outcome_fraction",
        "cost_policy",
        "outcome_policy",
        "retain_all_assigned_slices",
        "owner_actor_id"
      ],
      "properties": {
        "maximum_unknown_cost_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "maximum_missing_mature_outcome_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "cost_policy": { "const": "explicit_null_never_zero" },
        "outcome_policy": {
          "const": "retain_and_report_non_mature_by_assigned_arm"
        },
        "retain_all_assigned_slices": { "const": true },
        "owner_actor_id": { "$ref": "#/$defs/id" }
      }
    },
    "contamination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maximum_contaminated_fraction",
        "detection_method_id",
        "detection_method",
        "owner_actor_id",
        "retain_assigned_arm",
        "treatment_instruction_ref",
        "treatment_instruction_digest",
        "control_instruction_ref",
        "control_instruction_digest"
      ],
      "properties": {
        "maximum_contaminated_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "detection_method_id": { "$ref": "#/$defs/id" },
        "detection_method": { "$ref": "#/$defs/statement" },
        "owner_actor_id": { "$ref": "#/$defs/id" },
        "retain_assigned_arm": { "const": true },
        "treatment_instruction_ref": { "$ref": "#/$defs/reference" },
        "treatment_instruction_digest": { "$ref": "#/$defs/digest" },
        "control_instruction_ref": { "$ref": "#/$defs/reference" },
        "control_instruction_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "phase_leads": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Requirement",
        "Prototype",
        "Development",
        "QA",
        "ProjectDelivery"
      ],
      "properties": {
        "Requirement": { "$ref": "#/$defs/id_list" },
        "Prototype": { "$ref": "#/$defs/id_list" },
        "Development": { "$ref": "#/$defs/id_list" },
        "QA": { "$ref": "#/$defs/id_list" },
        "ProjectDelivery": { "$ref": "#/$defs/id_list" }
      }
    },
    "actors": {
      "type": "object",
      "description": "Frozen Stage 0-compatible authorization registry used when materializing observations. Runtime validation must also require these identities to agree with the corresponding roles registry; JSON Schema cannot compare arrays across properties.",
      "additionalProperties": false,
      "required": [
        "senders",
        "pms",
        "phase_leads",
        "certifiers",
        "experiment_owners",
        "metric_producers",
        "business_owners"
      ],
      "properties": {
        "senders": { "$ref": "#/$defs/id_list" },
        "pms": { "$ref": "#/$defs/id_list" },
        "phase_leads": { "$ref": "#/$defs/phase_leads" },
        "certifiers": { "$ref": "#/$defs/id_list" },
        "experiment_owners": { "$ref": "#/$defs/id_list" },
        "metric_producers": { "$ref": "#/$defs/id_list" },
        "business_owners": { "$ref": "#/$defs/id_list" }
      }
    },
    "roles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_owner_ids",
        "pm_ids",
        "sender_ids",
        "receiver_phase_lead_ids",
        "experiment_owner_ids",
        "assignment_custodian_ids",
        "metric_producer_ids",
        "guardrail_producer_ids",
        "external_reviewer_ids"
      ],
      "properties": {
        "business_owner_ids": { "$ref": "#/$defs/id_list" },
        "pm_ids": { "$ref": "#/$defs/id_list" },
        "sender_ids": { "$ref": "#/$defs/id_list" },
        "receiver_phase_lead_ids": { "$ref": "#/$defs/id_list" },
        "experiment_owner_ids": { "$ref": "#/$defs/id_list" },
        "assignment_custodian_ids": { "$ref": "#/$defs/id_list" },
        "metric_producer_ids": { "$ref": "#/$defs/id_list" },
        "guardrail_producer_ids": { "$ref": "#/$defs/id_list" },
        "external_reviewer_ids": { "$ref": "#/$defs/id_list" }
      }
    },
    "role_separation": {
      "type": "object",
      "description": "These frozen assertions are necessary but not sufficient: the pilot validator must also compare the role arrays and the external reviewer must authenticate the identities independently.",
      "additionalProperties": false,
      "required": [
        "external_reviewer_outside_same_uid",
        "external_reviewer_no_operational_role_overlap",
        "routine_receiver_is_not_pm",
        "assignment_custodian_not_metric_producer",
        "business_owner_not_metric_producer",
        "metric_producer_not_external_reviewer"
      ],
      "properties": {
        "external_reviewer_outside_same_uid": { "const": true },
        "external_reviewer_no_operational_role_overlap": { "const": true },
        "routine_receiver_is_not_pm": { "const": true },
        "assignment_custodian_not_metric_producer": { "const": true },
        "business_owner_not_metric_producer": { "const": true },
        "metric_producer_not_external_reviewer": { "const": true }
      }
    },
    "external_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "anchor_type",
        "anchor_ref",
        "anchor_digest",
        "anchored_at",
        "custodian_actor_id",
        "custody_principal",
        "outside_worker_writable_repository"
      ],
      "properties": {
        "required": { "const": true },
        "anchor_type": {
          "enum": [
            "detached_signature",
            "external_timestamp",
            "separate_principal_custody"
          ]
        },
        "anchor_ref": { "$ref": "#/$defs/reference" },
        "anchor_digest": { "$ref": "#/$defs/digest" },
        "anchored_at": { "$ref": "#/$defs/timestamp" },
        "custodian_actor_id": { "$ref": "#/$defs/id" },
        "custody_principal": { "$ref": "#/$defs/reference" },
        "outside_worker_writable_repository": { "const": true }
      }
    },
    "analysis_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "estimand",
        "analysis_as_of",
        "comparison",
        "contamination_analysis",
        "missing_data_analysis",
        "business_decision_authority",
        "actuation"
      ],
      "properties": {
